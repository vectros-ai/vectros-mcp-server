{
  "name": "@vectros-ai/mcp-server",
  "version": "0.5.1",
  "description": "MCP server exposing Vectros hybrid search, structured records, and in-perimeter RAG/document-ask to MCP-aware desktop agents (Claude Desktop, Cursor, Code, Cline, Continue, VS Code).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vectros-ai/vectros-mcp-server",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://vectros.ai",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "vectros-mcp-server": "./dist/cli.js",
    "vectros-mcp-server-http": "./dist/cli-http.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test:unit": "node --test --test-isolation=none --test-concurrency=1 --import tsx tests/unit/*.test.ts",
    "test:integration": "node --test --test-isolation=none --test-concurrency=1 --import tsx tests/integration/*.test.ts",
    "test": "npm run test:unit && npm run test:integration",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "vectros",
    "hybrid-search",
    "rag",
    "claude-desktop"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "pino": "^9.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "@vectros-ai/sdk": "0.29.9-staging.12925493",
    "eslint": "^9.39.4",
    "globals": "^15.14.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.20.0"
  }
}
